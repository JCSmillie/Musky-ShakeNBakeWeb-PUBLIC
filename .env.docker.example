# -----------------------------------------------------------------------------
# Musky Docker Compose environment example
# Copy this file to ".env" before running docker compose.
# -----------------------------------------------------------------------------

TZ=America/New_York

# Host port for the Musky web UI
MUSKY_HTTP_PORT_FORWARD=8088

# Nora MariaDB access
# Default target is Nora's Docker port-forward from its own compose stack.
MUSKY_DB_HOST=host.docker.internal
MUSKY_DB_PORT=7306
MUSKY_DB_NAME=nora
MUSKY_DB_USER=nora
MUSKY_DB_PASS=nora_password
MUSKY_DB_WAIT_ATTEMPTS=90
MUSKY_DB_WAIT_SLEEP_SECONDS=2

# Container build inputs
MUSKY_MOSBASIC_REPO=https://github.com/JCSmillie/MOSBasic.git
MUSKY_MOSBASIC_REF=main

# Core app behavior
MUSKY_SESSION_TIMEOUT_SECONDS=1800
MUSKY_DEVICE_MANAGER_ENABLED=1
MUSKY_LOANER_ENABLED=0

# Identity defaults
MUSKY_ALLOWED_EMAIL_DOMAINS=example.org,example.net
MUSKY_STAFF_DOMAINS=example.org
MUSKY_STUDENT_DOMAINS=example.net
MUSKY_HDK_DOMAINS=example.net
MUSKY_RESTRICTED_INDIVIDUAL_DOMAINS=example.net
MUSKY_TEACHER_EMAIL_DOMAIN=example.org
MUSKY_USERNAME_LOOKUP_DOMAINS=example.net,example.org

# Contact / notification defaults
MUSKY_PROBLEM_REPORT_TO=helpdesk@example.org
MUSKY_EMAIL_SENDER_ADDRESS=noreply@example.org

# NoraAPI target inside the Musky container
MUSKY_NORA_API_BASE_URL=http://127.0.0.1/api/NoraAPI.php?path=

# Optional Google SSO placeholders
MUSKY_GOOGLE_CLIENT_ID=
MUSKY_GOOGLE_CLIENT_SECRET=
MUSKY_GOOGLE_REDIRECT_URI=http://localhost:8088/SSO/Google/callback.php
MUSKY_GOOGLE_SERVICE_KEYFILE=/var/lib/musky/GoogleCreds/musky-service.json
MUSKY_GOOGLE_IMPERSONATE_ADMIN=admin@example.org
MUSKY_GOOGLE_ALLOWED_DOMAINS=example.org
MUSKY_GOOGLE_ENABLE_DEBUG_LOGS=0
MUSKY_GOOGLE_DEBUG_LOG_DIR=/var/lib/musky/GoogleAuths
MUSKY_GOOGLE_DISABLE_TEMP_DEBUG_FILES=1

# Optional Mosyle file-based helper creds
MUSKY_MOSYLE_API_BASE_URL=https://managerapi.mosyle.com/v2
MUSKY_MOSYLE_API_KEY=
MUSKY_MOSYLE_API_USERNAME=
MUSKY_MOSYLE_API_PASSWORD=

